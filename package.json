{
    "name": "domaine-lapistoule-static",
    "packageManager": "npm@10.9.2",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "engines": {
        "node": "22.x"
    },
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "lint": "astro check",
        "test": "playwright test",
        "test:ui": "playwright test --ui",
        "test:debug": "playwright test --debug",
        "prepare": "husky"
    },
    "dependencies": {
        "@fontsource/cormorant-garamond": "^5.2.11",
        "@fontsource/montserrat": "^5.2.8",
        "astro": "^5.18.0",
        "lucide": "^0.555.0"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.6",
        "@astrojs/tailwind": "^6.0.0",
        "@playwright/test": "^1.57.0",
        "@types/node": "^24.10.1",
        "@typescript-eslint/eslint-plugin": "^8.48.0",
        "@typescript-eslint/parser": "^8.48.0",
        "autoprefixer": "^10.4.20",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^0.34.0",
        "eslint-plugin-prettier": "^5.5.4",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "playwright": "^1.57.0",
        "postcss": "^8.4.49",
        "prettier": "^3.7.2",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.2.2"
    },
    "lint-staged": {
        "*.{ts,astro}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{js,mjs,cjs,json,md,yml,yaml,css}": [
            "prettier --write"
        ]
    }
}
